# Copy this file to .env and fill in your real values.
# .env is gitignored — NEVER commit .env to git.
# .env.example IS committed — it shows what variables are needed without real values.

# Tink Open Banking (PSD2)
TINK_CLIENT_ID=your-tink-client-id-here
TINK_CLIENT_SECRET=your-tink-client-secret-here

# GoCardless Bank Account Data (if/when signup opens)
GOCARDLESS_SECRET_ID=your-gocardless-secret-id-here
GOCARDLESS_SECRET_KEY=your-gocardless-secret-key-here

# Azure ML (for BERT training job submission)
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_RESOURCE_GROUP=finance-tracker-rg
AZURE_ML_WORKSPACE=finance-tracker-ml

# Azure Data Lake Gen2 (financetrackerdl storage account)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...
AZURE_ADLS_CONTAINER=bronze

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance_tracker
